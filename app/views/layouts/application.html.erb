<!DOCTYPE html>
<html>
  <head>
    <%= favicon_link_tag 'logo.png' %>
    <title>Portifolio</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", defer: true %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">
    <%#= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
  <style>
  body {
    background-color: black;
}

.navbar {
    background-color: black !important;
}

.btn {
    color: #E50057 !important;
    border-color: #E50057 !important;
}

.btn:hover {
    color: #E50057 !important;
    background-color: white !important;
    border-color: #E50057 !important;
}

.img-logo {
    width: 248px;
}

@media (max-width: 767px) {
    .img-logo {
        width: 124px;
    }

    .navbar {
        text-align: center;
    }

    .nav-container {
        flex-direction: column;
        align-items: center;
    }

    .nav-buttons {
        margin-top: 20px;
    }

    .btn {
        font-size: 14px;
    } 
}

.nav-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.nav-buttons {
    display: flex;
}
.name-footer {
  color: #E50057 ;
  text-decoration: none;
  text-transform: uppercase;
  margin: 8px;
}

.name-footer:hover {
  color: white ;
}
.developer-info{
    color: white ;
}
</style>
 
    <div class="container">
        <div class="nav-container">
            <%= link_to root_path do %>
              <%= image_tag 'logo.png', class: "img-logo" %>
            <% end %>
            <nav class="navbar navbar-light bg-light">
                <div class="nav-buttons">
                    <%= link_to "Sobre mim", about_index_path, class: "btn btn-outline-success me-2" %>
                    <%= link_to "Projetos",  project_index_path, class: "btn btn-outline-success me-2" %>
                    <%= link_to "Contato",   contact_index_path, class: "btn btn-outline-success me-2" %>
                </div>
            </nav>
        </div>
        <%= yield %>
        <footer style="display: flex; justify-content: space-between; align-items: center;">
            <div class="footer-content">
                <div class="additional-info">
                    <div class="copyright developer-info">
                        &copy; <%= Time.now.year %> Todos os direitos reservados
                    </div>
                </div>
            </div>
            <div class="developer-info">
                Desenvolvido por: 
                <a href="https://www.instagram.com/lari_seviilha/" class="name-footer" target="_blank">
                  Larissa Sevilha
                </a> 
            </div>
        </footer> 
     </div> 
  </body>
</html>
